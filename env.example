# qwen-ane-llm Environment Configuration
# Copy this file to .env and adjust values

# Model Configuration
ANE_MODEL_ID=./models/Qwen3.5-2B
ANE_MODEL_NAME=qwen3.5-2B

# Binary path (optional, auto-detected)
# ANE_BINARY_PATH=./build/ane-lm

# Server Configuration
ANE_HOST=127.0.0.1
ANE_PORT=11222

# Generation Defaults
ANE_TEMPERATURE=0.7
ANE_MAX_TOKENS=2048
